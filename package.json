{
  "name": "hexkeylab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "node vite/dev-proxy.mjs",
    "build": "pnpm -r build",
    "typecheck": "tsc --noEmit",
    "analyze": "node --max-old-space-size=8192 --expose-gc analyzer/generate-samples.js",
    "test:composer": "node tools/composer-test/run.mjs full",
    "test:composer:fast": "node tools/composer-test/run.mjs fast",
    "check:heji": "node tools/heji-check.mjs"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
